-- JSON Library
local JSON = (function()
	local json = {}
	local function encode(v)
		if type(v) == "table" then
			local parts = {}
			local isArray = #v > 0 and next(v, #v) == nil
			if isArray then
				for _, val in ipairs(v) do table.insert(parts, encode(val)) end
				return "[" .. table.concat(parts, ",") .. "]"
			else
				for k, val in pairs(v) do
					table.insert(parts, '"'..tostring(k)..'":'..encode(val))
				end
				return "{" .. table.concat(parts, ",") .. "}"
			end
		elseif type(v) == "string" then
			return '"' .. v:gsub('"', '\\"') .. '"'
		elseif type(v) == "boolean" then
			return v and "true" or "false"
		elseif type(v) == "number" then
			return tostring(v)
		else
			return "null"
		end
	end
	json.encode = encode

	json.decode = function(str)
		if not str or str == "" then return {} end
		local success, result = pcall(function()
			local cleaned = str:gsub(":true", ": true"):gsub(":false", ": false")
			return loadstring("return " .. cleaned)()
		end)
		return success and result or {}
	end
	return json
end)()

