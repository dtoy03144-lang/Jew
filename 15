local function LoadSettings()
	if not isfile(SettingsFile) then
		return -- אין קובץ = משתמשים ב-defaults
	end

	local success, content = pcall(readfile, SettingsFile)
	if not success or not content or content == "" then
		return
	end

	local success2, decoded = pcall(function()
		return game:GetService("HttpService"):JSONDecode(content)
	end)

	if success2 and decoded and typeof(decoded) == "table" then
		-- כאן הטעינה האמיתית - רק מעדכן מה שיש בקובץ
		for k, v in pairs(decoded) do
			states[k] = v
		end
		print("✅ Settings Loaded Successfully")
	else
		warn("❌ Failed to decode settings file")
	end
end
